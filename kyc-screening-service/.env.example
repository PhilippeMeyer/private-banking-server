# Server
PORT=3000
NODE_ENV=development

# If your network does transparent TLS interception (Zscaler, corporate SSL
# inspection, etc.) — a sign of this is `curl -v https://example.com` showing
# an issuer like "Zscaler Inc." instead of the site's real CA — Node will
# fail every HTTPS request with "unable to get local issuer certificate"
# because it doesn't read the OS certificate store the way curl/browsers do.
# This is NOT something dotenv/.env can fix, since Node needs it before TLS
# initializes. Set it in your shell profile instead:
#   echo 'export NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt' >> ~/.bashrc
# (path may differ outside Debian/Ubuntu — wherever curl's own CAfile points,
# shown in `curl -v` output as "CAfile: ...")

# SQLite (swap for a Postgres connection string later without changing app code much,
# since data access is isolated in src/db)
SQLITE_PATH=./data/kyc.db

# --- Source URLs (override with real/current endpoints; these change over time) ---
# OFAC retired www.treasury.gov/ofac/downloads/* in 2024 in favor of the
# Sanctions List Service (SLS). The old URLs redirect here, but the new host
# 403s any request without a User-Agent header (see ofac.ts fetchText()).
OFAC_SDN_XML_URL=https://sanctionslistservice.ofac.treas.gov/api/PublicationPreview/exports/SDN.XML
OFAC_CONSOLIDATED_XML_URL=https://sanctionslistservice.ofac.treas.gov/api/PublicationPreview/exports/CONSOLIDATED.XML
UN_CONSOLIDATED_XML_URL=https://scsanctions.un.org/resources/xml/en/consolidated.xml
# The EU Financial Sanctions Files portal REQUIRES a registered EU Login
# account and a per-user token — the URL below will 403 as-is. Register at
# https://webgate.ec.europa.eu/fsd/fsf, then after logging in find "Show
# settings for crawler/robot" and copy the exact URL shown there (it will
# include "?token=<your-username>"). This is confirmed required, not optional.
EU_CONSOLIDATED_XML_URL=https://webgate.ec.europa.eu/fsd/fsf/public/files/xmlFullSanctionsList_1_1/content

# UK Sanctions List (UKSL) — replaced the old OFSI Consolidated List entirely
# as of 28 January 2026. This static URL is verified against the live file.
UK_SANCTIONS_LIST_XML_URL=https://sanctionslist.fcdo.gov.uk/docs/UK-Sanctions-List.xml

# Japan MOF Economic Sanctions List — published as XLSX only, no XML/JSON/API.
# IMPORTANT: the column names below are placeholders, NOT verified against
# the live file (likely Japanese-language headers). Download the file from
# the URL below, open it, and set these to the real header names before
# relying on this source — the importer logs the actual headers it finds
# on every run to help with this.
JP_MOF_XLSX_URL=https://www.mof.go.jp/policy/international_policy/gaitame_kawase/gaitame/economic_sanctions/list.html
JP_MOF_COLUMN_NAME=Name
JP_MOF_COLUMN_ALIASES=
JP_MOF_COLUMN_DOB=
JP_MOF_COLUMN_NATIONALITY=
JP_MOF_COLUMN_ADDRESS=
JP_MOF_COLUMN_PROGRAM=

# OpenSanctions (aggregator covering ~100+ jurisdictions incl. Singapore,
# Hong Kong, plus alternates for UK/Japan). LICENSING: free for non-commercial
# use under CC BY-NC 4.0 — whether your use qualifies is a judgment call to
# make yourself (ideally with legal/compliance input), not something this
# code determines. Set the line below only after making that call either way.
OPENSANCTIONS_CSV_URL=
OPENSANCTIONS_LICENSE_CONFIRMED=false

# PEP data specifically: OpenSanctions recommends downloading the full
# "default" collection and filtering by topic, NOT their standalone `peps`
# collection (which is missing enrichment data — see their FAQ). This is a
# full FollowTheMoney entity stream (one JSON object per line), can be large,
# and is imported by streaming rather than loading it all into memory.
#
# If you already have the entities.ftm.json file on disk, point this at it
# directly — the importer reads it with no network request at all. Leave
# blank to fetch OPENSANCTIONS_FTM_URL over HTTP instead.
OPENSANCTIONS_FTM_FILE_PATH=./data/entities.ftm
OPENSANCTIONS_FTM_URL=https://data.opensanctions.org/datasets/latest/default/entities.ftm.json
OPENSANCTIONS_PEP_TOPICS=role.pep,role.rca

# --- Commercial PEP / adverse media vendor (plug in whichever you license) ---
PEP_VENDOR_API_URL=
PEP_VENDOR_API_KEY=
ADVERSE_MEDIA_VENDOR_API_URL=
ADVERSE_MEDIA_VENDOR_API_KEY=

# --- Scheduling (cron syntax) ---
IMPORT_CRON_OFAC=0 3 * * *
IMPORT_CRON_UN=0 3 * * *
IMPORT_CRON_EU=0 3 * * *
IMPORT_CRON_UK=0 3 * * *
IMPORT_CRON_JP_MOF=0 4 * * *
IMPORT_CRON_OPENSANCTIONS=0 6 * * *
IMPORT_CRON_PEP=0 4 * * *
IMPORT_CRON_ADVERSE_MEDIA=0 5 * * *

# --- Matching thresholds ---
FUZZY_MATCH_THRESHOLD=0.82
FUZZY_MATCH_REVIEW_THRESHOLD=0.65
